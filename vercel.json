{
    "cleanUrls": true,
    "redirects": [
        {
            "source": "/",
            "destination": "/termos",
            "permanent": false
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "www.pulsedge.com.br"
                }
            ],
            "destination": "https://pulsedge.com.br/:path*",
            "permanent": true
        }
    ]
}